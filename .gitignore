# ignore secrets and user config
.env
config.json
ca/

# Aras-GP Panel state — holds the admin password hash, the Flask session key,
# saved config profiles, an optional Cloudflare API token and the licence file.
panel/data/
*.license.key
aras-license-key.pem

# ignore python venv
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
*.spec

# IDE
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temp MITM certs
domainfront_certs_*/

# Background runner artefacts
panel/data/panel.pid
panel/data/panel.log

# A clone accidentally made inside the repo itself
/Aras-GP/
